---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Portfolio from '../../components/Portfolio.astro';
import Process from '../../components/Process.astro';
import ValueSection from '../../components/ValueSection.astro';
import MidCTA from '../../components/MidCTA.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';

const title = 'AXION Services AI';
const description = 'We design and build fast, scalable, conversion-focused websites powered by modern technologies and artificial intelligence.';
const lang = 'en';
---

<BaseLayout title={title} description={description} lang={lang}>
  <Header />
  <main>
    <Hero />
    <Services />
    <Portfolio />
    <Process />
    <ValueSection />
    <MidCTA />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
