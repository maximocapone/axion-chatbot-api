---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contact" class="py-6 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-4">
        <h2 class="text-xl md:text-2xl font-serif font-bold text-dark mb-1">
          {t('contact.title')}
        </h2>
        <p class="text-lg text-gray-600">
          {t('contact.subtitle')}
        </p>
      </div>
      
      <!-- Contact Form -->
      <form id="contact-form" class="space-y-2">
        <div>
          <label for="name" class="block text-sm font-semibold text-dark mb-1">
            {t('contact.name')}
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-copper focus:outline-none focus:ring-2 focus:ring-copper/20 transition-all duration-200"
          />
        </div>
        
        <div>
          <label for="email" class="block text-sm font-semibold text-dark mb-1">
            {t('contact.email')}
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-copper focus:outline-none focus:ring-2 focus:ring-copper/20 transition-all duration-200"
          />
        </div>
        
        <div>
          <label for="company" class="block text-sm font-semibold text-dark mb-1">
            {t('contact.company')}
          </label>
          <input 
            type="text" 
            id="company" 
            name="company"
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-copper focus:outline-none focus:ring-2 focus:ring-copper/20 transition-all duration-200"
          />
        </div>
        
        <div>
          <label for="message" class="block text-sm font-semibold text-dark mb-1">
            {t('contact.message')}
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows="2" 
            required
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-copper focus:outline-none focus:ring-2 focus:ring-copper/20 transition-all duration-200 resize-none"
          ></textarea>
        </div>
        
        <button 
          type="submit"
          class="w-full bg-brand-red text-white px-8 py-4 rounded-lg font-bold text-base hover:bg-brand-red-hover hover:scale-[1.02] transition-all duration-200 shadow-lg hover:shadow-xl"
        >
          {t('contact.submit')}
        </button>
        
        <!-- Success Message -->
        <div id="success-message" class="hidden p-4 bg-green-50 border-2 border-green-500 rounded-lg">
          <p class="text-green-700 font-semibold text-center">
            {t('contact.success')}
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');
  
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Simulate form submission
    const formData = new FormData(form);
    
    // Show success message
    successMessage?.classList.remove('hidden');
    form.reset();
    
    // Hide success message after 5 seconds
    setTimeout(() => {
      successMessage?.classList.add('hidden');
    }, 5000);
  });
</script>
