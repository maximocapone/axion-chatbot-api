---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="services" class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <p class="text-sm uppercase tracking-wider text-copper font-semibold mb-4">
        {t('services.label')}
      </p>
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-dark mb-6">
        {t('services.title')}
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {t('services.subtitle')}
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Service 1: Full-Stack -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.fullstack.title')}
        </h3>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.fullstack.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>
      
      <!-- Service 2: AI-Powered -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.ai.title')}
        </h3>
        <p class="text-copper font-semibold mb-2">
          {t('services.ai.tagline')}
        </p>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.ai.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>
      
      <!-- Service 3: UX/UI Design -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="3" y="8" width="18" height="12" rx="2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2v6M8 2h8" />
            <circle cx="9" cy="13" r="1.2" fill="currentColor"/>
            <circle cx="15" cy="13" r="1.2" fill="currentColor"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17h6" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12H1m22 0h-2" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.ux.title')}
        </h3>
        <p class="text-copper font-semibold mb-2">
          {t('services.ux.tagline')}
        </p>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.ux.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>
      
      <!-- Service 4: Performance & SEO -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.performance.title')}
        </h3>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.performance.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>

      <!-- Service 5: Automation -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="3" stroke-width="1.5"/>
            <circle cx="4" cy="6" r="2" stroke-width="1.5"/>
            <circle cx="20" cy="6" r="2" stroke-width="1.5"/>
            <circle cx="4" cy="18" r="2" stroke-width="1.5"/>
            <circle cx="20" cy="18" r="2" stroke-width="1.5"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 6.5l4.5 4M17.5 6.5L13 10M6 17.5l4.5-4M17.5 17.5L13 14" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.automation.title')}
        </h3>
        <p class="text-copper font-semibold mb-2">
          {t('services.automation.tagline')}
        </p>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.automation.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>

      <!-- Service 6: Analytics -->
      <div class="group p-8 bg-white border-2 border-gray-200 rounded-2xl hover:border-copper hover:shadow-2xl transition-all duration-300 cursor-pointer">
        <div class="mb-6">
          <svg class="w-16 h-16 text-copper group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-2xl font-serif font-bold text-dark mb-4">
          {t('services.analytics.title')}
        </h3>
        <p class="text-copper font-semibold mb-2">
          {t('services.analytics.tagline')}
        </p>
        <ul class="text-gray-600 leading-relaxed space-y-1 list-none">
          {t('services.analytics.description').split('·').map(item => (
            <li class="flex items-start gap-2"><span class="text-copper font-bold mt-0.5">•</span><span>{item.trim()}</span></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
