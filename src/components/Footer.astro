---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="bg-dark text-white py-16">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand Section -->
      <div>
        <img src="/logo/logo.svg" alt="AXION Web AI" class="h-10 w-auto mb-4 brightness-0 invert" />
        <p class="text-gray-400 text-sm leading-relaxed">
          {t('footer.tagline')}
        </p>
      </div>
      
      <!-- Navigation -->
      <div>
        <h3 class="font-serif text-lg mb-4 text-copper">Navigation</h3>
        <ul class="space-y-2">
          <li>
            <a href={`/${lang}#services`} class="text-gray-400 hover:text-white transition-colors">
              {t('nav.services')}
            </a>
          </li>
          <li>
            <a href={`/${lang}#process`} class="text-gray-400 hover:text-white transition-colors">
              {t('nav.process')}
            </a>
          </li>
          <li>
            <a href={`/${lang}#work`} class="text-gray-400 hover:text-white transition-colors">
              {t('nav.work')}
            </a>
          </li>
          <li>
            <a href={`/${lang}#contact`} class="text-gray-400 hover:text-white transition-colors">
              {t('nav.contact')}
            </a>
          </li>
        </ul>
      </div>
      
      <!-- Contact & Language -->
      <div>
        <h3 class="font-serif text-lg mb-4 text-copper">Contact</h3>
        <p class="text-gray-400 mb-4">
          <a href="mailto:hello@axionweb.ai" class="hover:text-white transition-colors">
            hello@axionweb.ai
          </a>
        </p>
        
        <div class="flex items-center space-x-2 mt-6">
          <span class="text-sm text-gray-400">Language:</span>
          <a href="/en" class={`text-sm ${lang === 'en' ? 'text-copper' : 'text-gray-400 hover:text-white'} transition-colors`}>
            EN
          </a>
          <span class="text-gray-600">|</span>
          <a href="/es" class={`text-sm ${lang === 'es' ? 'text-copper' : 'text-gray-400 hover:text-white'} transition-colors`}>
            ES
          </a>
        </div>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="pt-8 border-t border-gray-800 text-center text-gray-500 text-sm">
      {t('footer.copyright')}
    </div>
  </div>
</footer>
